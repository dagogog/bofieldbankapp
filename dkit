<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<script>

  let balance = 12485.92;
  const fmt = n => '€' + n.toLocaleString('en-IE', {minimumFractionDigits:2, maximumFractionDigits:2});

  // ── Page navigation ──
  function showPage(name) {
    document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.nav-link').forEach(l => l.classList.remove('active'));
    document.getElementById('page-' + name).classList.add('active');
    document.getElementById('nav-' + name).classList.add('active');
    // close mobile nav if open
    const navCollapse = document.getElementById('nav');
    if (navCollapse.classList.contains('show')) {
      new bootstrap.Collapse(navCollapse).hide();
    }
  }

  // ── Send Money ──
  const sendModal   = document.getElementById('sendModal');
  const formView    = document.getElementById('formView');
  const successView = document.getElementById('successView');
  const balanceEl   = document.getElementById('balanceDisplay');
  const txList      = document.getElementById('transactionList');
  const recipientEl = document.getElementById('recipient');
  const amountEl    = document.getElementById('amount');
  const noteEl      = document.getElementById('note');

  function openSendModal() {
    sendModal.classList.add('active');
    recipientEl.value=''; amountEl.value=''; noteEl.value='';
    ['recipientError','amountError','fundsError'].forEach(id => document.getElementById(id).style.display='none');
    formView.style.display='block'; successView.style.display='none';
    recipientEl.focus();
  }
  function closeSendModal() { sendModal.classList.remove('active'); }

  function sendMoney() {
    let ok = true;
    ['recipientError','amountError','fundsError'].forEach(id => document.getElementById(id).style.display='none');
    if (!recipientEl.value.trim()) { document.getElementById('recipientError').style.display='block'; ok=false; }
    const amt = parseFloat(amountEl.value);
    if (!amountEl.value || isNaN(amt) || amt <= 0) { document.getElementById('amountError').style.display='block'; ok=false; }
    else if (amt > balance) { document.getElementById('fundsError').style.display='block'; ok=false; }
    if (!ok) return;

    const a = parseFloat(amt.toFixed(2));
    const recipient = recipientEl.value.trim();
    const note = noteEl.value.trim();
    balance -= a;
    balanceEl.textContent = fmt(balance);

    const tx = document.createElement('div');
    tx.className = 'transaction new-entry';
    tx.innerHTML = '<span>' + recipient + (note ? ' <span style="color:var(--muted);font-size:.8rem">· ' + note + '</span>' : '') + '</span><span class="negative">-' + fmt(a) + '</span>';
    txList.insertBefore(tx, txList.firstChild);

    document.getElementById('successAmount').textContent    = fmt(a);
    document.getElementById('successRecipient').textContent = recipient;
    document.getElementById('successNote').textContent      = note;
    formView.style.display='none'; successView.style.display='block';
  }

  document.getElementById('sendMoneyBtn').addEventListener('click', openSendModal);
  document.getElementById('closeModal').addEventListener('click', closeSendModal);
  document.getElementById('doneBtn').addEventListener('click', closeSendModal);
  document.getElementById('confirmSend').addEventListener('click', sendMoney);
  sendModal.addEventListener('click', e => { if (e.target===sendModal) closeSendModal(); });
  [amountEl, noteEl].forEach(el => el.addEventListener('keydown', e => { if (e.key==='Enter') sendMoney(); }));

  // ── Request Money ──
  const requestModal = document.getElementById('requestModal');
  const reqFormView  = document.getElementById('reqFormView');
  const reqSuccView  = document.getElementById('reqSuccessView');
  const reqFromEl    = document.getElementById('reqFrom');
  const reqAmountEl  = document.getElementById('reqAmount');
  const reqNoteEl    = document.getElementById('reqNote');
  const copyLinkBtn  = document.getElementById('copyLinkBtn');

  function openRequestModal() {
    requestModal.classList.add('active');
    reqFromEl.value=''; reqAmountEl.value=''; reqNoteEl.value='';
    ['reqFromError','reqAmountError'].forEach(id => document.getElementById(id).style.display='none');
    reqFormView.style.display='block'; reqSuccView.style.display='none';
    reqFromEl.focus();
  }
  function closeRequestModal() { requestModal.classList.remove('active'); }

  function requestMoney() {
    let ok = true;
    ['reqFromError','reqAmountError'].forEach(id => document.getElementById(id).style.display='none');
    if (!reqFromEl.value.trim()) { document.getElementById('reqFromError').style.display='block'; ok=false; }
    const amt = parseFloat(reqAmountEl.value);
    if (!reqAmountEl.value || isNaN(amt) || amt <= 0) { document.getElementById('reqAmountError').style.display='block'; ok=false; }
    if (!ok) return;

    const a    = parseFloat(amt.toFixed(2));
    const from = reqFromEl.value.trim();
    const note = reqNoteEl.value.trim();
    const slug = from.toLowerCase().replace(/\s+/g,'-').replace(/[^a-z0-9-]/g,'');
    const params = new URLSearchParams({to:slug, amt:a.toFixed(2)});
    if (note) params.set('ref', note);
    const link = 'https://bofields.bank/pay?' + params.toString();

    document.getElementById('reqSuccessAmount').textContent = fmt(a);
    document.getElementById('reqSuccessFrom').textContent   = from;
    document.getElementById('reqSuccessNote').textContent   = note;
    document.getElementById('payLink').textContent          = link;
    copyLinkBtn.innerHTML = '<i class="bi bi-clipboard"></i>';
    copyLinkBtn.classList.remove('copied');
    reqFormView.style.display='none'; reqSuccView.style.display='block';
  }

  document.getElementById('requestBtn').addEventListener('click', openRequestModal);
  document.getElementById('closeRequestModal').addEventListener('click', closeRequestModal);
  document.getElementById('reqDoneBtn').addEventListener('click', closeRequestModal);
  document.getElementById('confirmRequest').addEventListener('click', requestMoney);
  requestModal.addEventListener('click', e => { if (e.target===requestModal) closeRequestModal(); });
  [reqAmountEl, reqNoteEl].forEach(el => el.addEventListener('keydown', e => { if (e.key==='Enter') requestMoney(); }));

  copyLinkBtn.addEventListener('click', () => {
    navigator.clipboard.writeText(document.getElementById('payLink').textContent).then(() => {
      copyLinkBtn.innerHTML = '<i class="bi bi-clipboard-check"></i>';
      copyLinkBtn.classList.add('copied');
      setTimeout(() => { copyLinkBtn.innerHTML='<i class="bi bi-clipboard"></i>'; copyLinkBtn.classList.remove('copied'); }, 2000);
    });
  });

  document.addEventListener('keydown', e => { if (e.key==='Escape') { closeSendModal(); closeRequestModal(); } });
</script>

</body>
</html>
