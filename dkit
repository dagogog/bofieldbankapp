      <div class="success-view">
        <div class="request-success-icon"><i class="bi bi-link-45deg"></i></div>
        <div style="font-size:1.4rem;font-weight:700;color:#a855f7" id="reqSuccessAmount"></div>
        <div class="success-sub">requested from <strong id="reqSuccessFrom"></strong></div>
        <div class="success-sub mt-1" style="font-size:.8rem;opacity:.6" id="reqSuccessNote"></div>
        <div class="form-label mt-3" style="text-align:left">Payment link</div>
        <div class="link-box">
          <span id="payLink"></span>
          <button class="copy-btn" id="copyLinkBtn" title="Copy link"><i class="bi bi-clipboard"></i></button>
        </div>
        <button class="btn-done-purple" id="reqDoneBtn">Done</button>
      </div>
    </div>
  </div>
