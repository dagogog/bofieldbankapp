            </select>
          </div>
          <div class="payment-row">
            <div class="pay-icon out"><i class="bi bi-arrow-up-right"></i></div>
            <div class="pay-meta"><div class="pay-name">Apple Store</div><div class="pay-date">Apr 5, 2026 · 14:32</div></div>
            <div class="text-end"><div class="negative fw-semibold">-€249.00</div><span class="pay-status completed">Completed</span></div>
          </div>
          <div class="payment-row">
            <div class="pay-icon in"><i class="bi bi-arrow-down-left"></i></div>
            <div class="pay-meta"><div class="pay-name">Salary Payment</div><div class="pay-date">Apr 1, 2026 · 09:00</div></div>
            <div class="text-end"><div class="positive fw-semibold">+€3,200.00</div><span class="pay-status completed">Completed</span></div>
          </div>
          <div class="payment-row">
            <div class="pay-icon out"><i class="bi bi-arrow-up-right"></i></div>
            <div class="pay-meta"><div class="pay-name">Gym Membership</div><div class="pay-date">Mar 31, 2026 · 08:15</div></div>
