<div class="modal-overlay" id="requestModal">
  <div class="modal-box">
    <div id="reqFormView">
      <div class="modal-title">
        <span><i class="bi bi-arrow-down-circle me-2" style="color:#a855f7"></i>Request Money</span>
        <button class="modal-close" id="closeRequestModal">&times;</button>
      </div>
      <div class="mb-3">
        <div class="form-label">Request from (name or email)</div>
        <input type="text" id="reqFrom" class="form-control-dark" placeholder="e.g. Jane Smith">
        <div class="error-msg" id="reqFromError">Please enter a name or email.</div>
      </div>
      <div class="mb-3">
        <div class="form-label">Amount (€)</div>
        <div class="amount-wrapper">
          <span class="amount-prefix">€</span>
          <input type="number" id="reqAmount" class="form-control-dark has-prefix" placeholder="0.00" min="0.01" step="0.01">
        </div>
