        <input id="authEmail" class="auth-input" type="userID" placeholder="User ID" autocomplete="userid">
        <input id="authPassword" class="auth-input" type="password" placeholder="Password" autocomplete="current-password">

        <div style="display:flex;gap:.6rem">
          <button id="signInBtn" class="auth-btn">Sign in</button>
          <button id="showSignupBtn" class="auth-ghost">Sign up</button>
