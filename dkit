<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<title>Bofields Bank – Mobile Banking</title>
<meta name="viewport" content="width=device-width, initial-scale=1">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
<style>
:root{--bg:#02040a;--accent:#4f9cff;--text:#f5f7ff;--muted:#a7afc7;--danger:#ff4f6a;--success:#37e29b;--radius:1.2rem;}
body{background:radial-gradient(circle at top,#101530 0,#02040a 55%,#000 100%);min-height:100vh;color:var(--text);font-family:system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;}
.navbar{background:rgba(2,4,10,.95);backdrop-filter:blur(18px);border-bottom:1px solid rgba(255,255,255,.08);}
.navbar .nav-link{color:var(--muted);cursor:pointer;}.navbar .nav-link:hover{color:var(--text);}
.navbar .nav-link.active{color:var(--text) !important;font-weight:500;}
.hero{padding:4rem 0 2rem;}.hero h1{font-size:clamp(2rem,4vw,2.6rem);font-weight:600;}.hero p{color:var(--muted);max-width:32rem;}
.glass{background:rgba(10,16,35,.88);border:1px solid rgba(255,255,255,.1);border-radius:var(--radius);backdrop-filter:blur(20px);box-shadow:0 18px 45px rgba(0,0,0,.7);}
.glass-inner{padding:1.4rem;}.balance{font-size:1.6rem;font-weight:600;}
.btn-accent{border-radius:999px;padding:.6rem 1.4rem;background:linear-gradient(135deg,#4f9cff,#4f6cff);border:none;color:#fff;box-shadow:0 12px 25px rgba(79,156,255,.45);cursor:pointer;transition:filter .2s,transform .15s;}
.btn-accent:hover{filter:brightness(1.1);transform:translateY(-1px);}.btn-accent:active{transform:translateY(0);}
.feature-icon{width:42px;height:42px;border-radius:50%;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,rgba(79,156,255,.25),rgba(55,226,155,.15));border:1px solid rgba(255,255,255,.12);font-size:1.2rem;}
.transaction{display:flex;justify-content:space-between;align-items:center;padding:.55rem 0;border-bottom:1px solid rgba(255,255,255,.05);}
.transaction:last-child{border-bottom:none;}.transaction.new-entry{animation:slideIn .4s ease;}
@keyframes slideIn{from{opacity:0;transform:translateY(-8px);}to{opacity:1;transform:translateY(0);}}
.negative{color:var(--danger);}.positive{color:var(--success);}
.chart{display:flex;align-items:flex-end;gap:.4rem;height:120px;margin-top:.5rem;}
.bar{flex:1;background:linear-gradient(180deg,#4f9cff,#4f6cff);border-radius:999px;}
.bar1{height:40%}.bar2{height:65%}.bar3{height:50%}.bar4{height:80%}.bar5{height:70%}.bar6{height:55%}
.section-title{font-size:.85rem;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);margin-bottom:.7rem;}

/* ── Page switching ── */
.page{display:none;animation:fadeIn .25s ease;}
.page.active{display:block;}
@keyframes fadeIn{from{opacity:0;transform:translateY(10px);}to{opacity:1;transform:translateY(0);}}

/* ── Payments page ── */
.payment-row{display:flex;align-items:center;gap:1rem;padding:.7rem 0;border-bottom:1px solid rgba(255,255,255,.05);}
.payment-row:last-child{border-bottom:none;}
.pay-icon{width:38px;height:38px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0;}
.pay-icon.out{background:rgba(255,79,106,.15);color:var(–danger);}
.pay-icon.in{background:rgba(55,226,155,.15);color:var(–success);}
.pay-meta{flex:1;}.pay-name{font-size:.92rem;font-weight:500;}.pay-date{font-size:.75rem;color:var(–muted);}
.pay-status{font-size:.72rem;padding:.18rem .55rem;border-radius:999px;font-weight:600;}
.pay-status.completed{background:rgba(55,226,155,.15);color:var(–success);}
.pay-status.pending{background:rgba(255,196,0,.15);color:#ffc400;}

/* ── Cards page ── */
.card-visual{border-radius:1.2rem;padding:1.5rem;background:linear-gradient(135deg,#1a2a6c,#4f6cff,#4f9cff);position:relative;overflow:hidden;min-height:160px;margin-bottom:1rem;}
.card-visual::before{content:’’;position:absolute;top:-40px;right:-40px;width:160px;height:160px;border-radius:50%;background:rgba(255,255,255,.07);}
.card-visual::after{content:’’;position:absolute;bottom:-50px;left:30px;width:120px;height:120px;border-radius:50%;background:rgba(255,255,255,.05);}
.card-chip{width:36px;height:28px;border-radius:5px;background:linear-gradient(135deg,#d4a843,#f0c96b);margin-bottom:1rem;}
.card-number{font-size:1rem;letter-spacing:.18em;font-family:monospace;margin-bottom:.6rem;}
.card-footer-row{display:flex;justify-content:space-between;align-items:flex-end;}
.card-label{font-size:.65rem;text-transform:uppercase;letter-spacing:.1em;color:rgba(255,255,255,.6);}
.card-value{font-size:.88rem;font-weight:600;}
.card-brand{font-size:1.5rem;color:rgba(255,255,255,.9);}
.toggle-row{display:flex;justify-content:space-between;align-items:center;padding:.65rem 0;border-bottom:1px solid rgba(255,255,255,.05);}
.toggle-row:last-child{border-bottom:none;}
.toggle-label{font-size:.9rem;}.toggle-sub{font-size:.75rem;color:var(–muted);}
.toggle{position:relative;width:42px;height:24px;flex-shrink:0;}
.toggle input{opacity:0;width:0;height:0;}
.toggle-slider{position:absolute;inset:0;background:rgba(255,255,255,.15);border-radius:999px;cursor:pointer;transition:.3s;}
.toggle-slider:before{content:’’;position:absolute;width:18px;height:18px;left:3px;top:3px;background:#fff;border-radius:50%;transition:.3s;}
.toggle input:checked + .toggle-slider{background:var(–accent);}
.toggle input:checked + .toggle-slider:before{transform:translateX(18px);}


/* ── Settings page ── */
.settings-row{display:flex;align-items:center;gap:1rem;padding:.75rem 0;border-bottom:1px solid rgba(255,255,255,.05);cursor:pointer;transition:background .2s;border-radius:.5rem;}
.settings-row:last-child{border-bottom:none;}
.settings-row:hover{background:rgba(255,255,255,.03);}
.settings-icon{width:38px;height:38px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0;}
.settings-label{flex:1;font-size:.92rem;font-weight:500;}
.settings-sub{font-size:.75rem;color:var(–muted);}
.settings-chevron{color:var(–muted);font-size:.9rem;}
.avatar{width:64px;height:64px;border-radius:50%;background:linear-gradient(135deg,#4f9cff,#4f6cff);display:flex;align-items:center;justify-content:center;font-size:1.6rem;font-weight:700;margin:0 auto .6rem;}
.notification-badge{display:inline-block;background:var(–danger);color:#fff;font-size:.65rem;font-weight:700;border-radius:999px;padding:.1rem .4rem;margin-left:.4rem;}

/* ── Modals ── */
.modal-overlay{display:none;position:fixed;inset:0;z-index:1000;background:rgba(0,0,0,.65);backdrop-filter:blur(6px);align-items:center;justify-content:center;}
.modal-overlay.active{display:flex;}
.modal-box{background:linear-gradient(160deg,#0d1630,#07101f);border:1px solid rgba(255,255,255,.13);border-radius:1.5rem;padding:2rem;width:min(92vw,420px);box-shadow:0 30px 70px rgba(0,0,0,.8);animation:popIn .25s cubic-bezier(.34,1.56,.64,1);}
@keyframes popIn{from{opacity:0;transform:scale(.92) translateY(20px);}to{opacity:1;transform:scale(1) translateY(0);}}
.modal-title{font-size:1.2rem;font-weight:600;margin-bottom:1.4rem;display:flex;justify-content:space-between;align-items:center;}
.modal-close{background:none;border:none;color:var(–muted);font-size:1.3rem;cursor:pointer;line-height:1;padding:.2rem .4rem;border-radius:.4rem;transition:color .2s,background .2s;}
.modal-close:hover{color:var(–text);background:rgba(255,255,255,.07);}
.form-label{color:var(–muted);font-size:.82rem;margin-bottom:.35rem;}
.form-control-dark{background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);border-radius:.75rem;color:var(–text);padding:.65rem 1rem;width:100%;font-size:.95rem;transition:border-color .2s,box-shadow .2s;outline:none;}
.form-control-dark::placeholder{color:rgba(167,175,199,.5);}
.form-control-dark:focus{border-color:var(–accent);box-shadow:0 0 0 3px rgba(79,156,255,.2);}
.amount-wrapper{position:relative;}
.amount-prefix{position:absolute;left:1rem;top:50%;transform:translateY(-50%);color:var(–muted);font-size:.95rem;pointer-events:none;}
.form-control-dark.has-prefix{padding-left:2rem;}
.error-msg{color:var(–danger);font-size:.78rem;margin-top:.3rem;display:none;}
.btn-send-confirm{width:100%;padding:.75rem;border-radius:999px;background:linear-gradient(135deg,#4f9cff,#4f6cff);border:none;color:#fff;font-size:1rem;font-weight:600;cursor:pointer;box-shadow:0 10px 28px rgba(79,156,255,.4);transition:filter .2s,transform .15s;margin-top:1.2rem;}
.btn-send-confirm:hover{filter:brightness(1.1);transform:translateY(-1px);}
.btn-request-confirm{width:100%;padding:.75rem;border-radius:999px;background:linear-gradient(135deg,#a855f7,#7c3aed);border:none;color:#fff;font-size:1rem;font-weight:600;cursor:pointer;box-shadow:0 10px 28px rgba(168,85,247,.4);transition:filter .2s,transform .15s;margin-top:1.2rem;}
.btn-request-confirm:hover{filter:brightness(1.1);transform:translateY(-1px);}
.request-success-icon{width:70px;height:70px;border-radius:50%;background:rgba(168,85,247,.15);border:2px solid #a855f7;display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;font-size:2rem;color:#a855f7;animation:popIn .35s cubic-bezier(.34,1.56,.64,1);}
.link-box{background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);border-radius:.75rem;padding:.65rem 1rem;font-size:.82rem;color:var(–muted);word-break:break-all;margin-top:.8rem;display:flex;align-items:center;justify-content:space-between;gap:.5rem;}
.copy-btn{background:none;border:none;color:var(–accent);font-size:1.1rem;cursor:pointer;flex-shrink:0;transition:transform .15s;}
.copy-btn:hover{transform:scale(1.15);}.copy-btn.copied{color:var(–success);}
.btn-done-purple{margin-top:1.4rem;width:100%;padding:.7rem;border-radius:999px;background:rgba(168,85,247,.15);border:1px solid #a855f7;color:#a855f7;font-weight:600;font-size:.95rem;cursor:pointer;transition:background .2s;}
.btn-done-purple:hover{background:rgba(168,85,247,.25);}
.success-view{text-align:center;padding:1rem 0 .5rem;}
.success-icon{width:70px;height:70px;border-radius:50%;background:rgba(55,226,155,.15);border:2px solid var(–success);display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;font-size:2rem;color:var(–success);animation:popIn .35s cubic-bezier(.34,1.56,.64,1);}
.success-amount{font-size:1.8rem;font-weight:700;color:var(–success);}
.success-sub{color:var(–muted);font-size:.9rem;margin-top:.3rem;}
.btn-done{margin-top:1.4rem;width:100%;padding:.7rem;border-radius:999px;background:rgba(55,226,155,.15);border:1px solid var(–success);color:var(–success);font-weight:600;font-size:.95rem;cursor:pointer;transition:background .2s;}
.btn-done:hover{background:rgba(55,226,155,.25);}

/* Authentication / Login styles */
.auth-wrap{min-height:48vh;display:flex;align-items:center;justify-content:center;padding:2.5rem 0;}
.auth-card{width:100%;max-width:420px;background:rgba(8,14,28,.9);border:1px solid rgba(255,255,255,.06);border-radius:1rem;padding:1.4rem;box-shadow:0 18px 45px rgba(0,0,0,.6);}
.auth-title{font-size:1.2rem;font-weight:700;margin-bottom:.25rem;}
.auth-sub{color:var(--muted);font-size:.9rem;margin-bottom:1rem;}
.auth-input{width:100%;padding:.7rem 1rem;border-radius:.8rem;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.06);color:var(--text);margin-bottom:.8rem;outline:none;}
.auth-actions{display:flex;gap:.6rem;align-items:center;justify-content:space-between;margin-top:.6rem;}
.auth-btn{flex:1;padding:.6rem 1rem;border-radius:999px;border:0;background:linear-gradient(135deg,#4f9cff,#4f6cff);color:#fff;font-weight:700;cursor:pointer;}
.auth-ghost{flex:1;padding:.6rem 1rem;border-radius:999px;border:1px solid rgba(255,255,255,.06);background:transparent;color:var(--muted);cursor:pointer;}
.auth-switch{display:flex;gap:.5rem;justify-content:center;margin-top:.8rem;color:var(--muted);font-size:.9rem;}
.auth-error{color:var(--danger);font-size:.85rem;margin-top:.5rem;display:none;text-align:center;}


/* Contact page (enhanced) */
.contact-wrap{max-width:980px;margin:0 auto 2.5rem;}
.contact-grid{display:grid;grid-template-columns:320px 1fr;gap:1.25rem;align-items:start;}
@media (max-width:900px){.contact-grid{grid-template-columns:1fr;}}
.contact-panel{background:linear-gradient(180deg,rgba(255,255,255,.02),rgba(255,255,255,.01));border:1px solid rgba(255,255,255,.06);border-radius:1rem;padding:1.25rem;display:flex;flex-direction:column;gap:.8rem;}
.contact-brand{display:flex;align-items:center;gap:.75rem}
.contact-brand .avatar{width:48px;height:48px;border-radius:10px;font-size:1.05rem}
.contact-title{font-weight:700;font-size:1.05rem}
.contact-meta{color:var(--muted);font-size:.9rem}
.contact-list{margin-top:.6rem;display:flex;flex-direction:column;gap:.6rem}
.contact-item{display:flex;gap:.6rem;align-items:flex-start;color:var(--muted);font-size:.92rem}
.contact-item i{font-size:1.05rem;color:var(--accent);min-width:28px;text-align:center;margin-top:2px}

/* Form styling */
.contact-card{background:rgba(8,14,28,.9);border:1px solid rgba(255,255,255,.06);border-radius:1rem;padding:1.25rem;}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:.75rem}
@media (max-width:700px){.form-row{grid-template-columns:1fr}}
.form-label{display:block;color:var(--muted);font-size:.82rem;margin-bottom:.35rem}
.contact-input{width:100%;padding:.75rem 1rem;border-radius:.75rem;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.06);color:var(--text);outline:none;font-size:.95rem}
.contact-textarea{min-height:160px;resize:vertical;padding:.85rem 1rem;border-radius:.75rem;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.06);color:var(--text);outline:none;font-size:.95rem}
.contact-actions{display:flex;gap:.6rem;align-items:center;justify-content:flex-end;margin-top:.8rem}
.contact-clear{border-radius:999px;padding:.6rem 1rem;background:transparent;border:1px solid rgba(255,255,255,.06);color:var(--muted)}
.contact-send{border-radius:999px;padding:.6rem 1.1rem;background:linear-gradient(135deg,#4f9cff,#4f6cff);border:none;color:#fff;font-weight:700;cursor:pointer}
.contact-success{display:none;margin-top:.9rem;padding:.85rem;border-radius:.6rem;background:linear-gradient(90deg,rgba(55,226,155,.06),rgba(79,156,255,.03));border:1px solid rgba(55,226,155,.08);color:var(--success);text-align:center;font-weight:600}
.contact-error{display:none;color:var(--danger);font-size:.88rem;margin-top:.6rem;text-align:center}

/* small helper */
.field-inline{display:flex;gap:.6rem;align-items:center}
</style>



</head>
