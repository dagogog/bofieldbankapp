<!-- ── PAYMENTS PAGE ── -->

<div id="page-payments" class="page">
  <section class="hero container">
    <h1>Payments</h1>
    <p class="lead">Your full payment history and scheduled transfers.</p>
  </section>
  <section class="container pb-5">
    <div class="row g-4">
      <div class="col-lg-8">
        <div class="glass"><div class="glass-inner">
          <div class="d-flex justify-content-between align-items-center mb-3">
            <div class="section-title mb-0">All Transactions</div>
            <select class="form-control-dark" style="width:auto;padding:.35rem .8rem;font-size:.82rem;">
