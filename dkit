<!-- ── LOGIN / SIGN UP PAGE ── -->
<div id="page-login" class="page active">
  <section class="hero container">
    <h1>Welcome to Bofields Bank</h1>
    <p class="lead">Sign in to access your accounts or create a new account to get started.</p>
  </section>

  <section class="container pb-5">
    <div class="auth-wrap">
      <div class="auth-card glass-inner">
        <div style="text-align:center;margin-bottom:.6rem">
